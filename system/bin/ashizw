#!/system/bin/sh
# Ashizw - Shizuku Manager for KernelSU + Termux

CONFIG_DIR="/data/adb/.config/ashizw"
CONFIG_FILE="$CONFIG_DIR/config.json"
LOG_FILE="$CONFIG_DIR/ashizw.log"
LIB_CACHE="$CONFIG_DIR/lib_cache"
MODULE_ID="ashizw"

# Log max lines before rotation
LOG_MAX_LINES=500

mkdir -p "$CONFIG_DIR" 2>/dev/null

init_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        cat > "$CONFIG_FILE" << 'EOF'
{
  "boot_delay": 45,
  "check_interval": 1800
}
EOF
    fi
}
init_config

# -------------------------------------------------------------------
# Update KernelSU dynamic status
# -------------------------------------------------------------------
update_ksu_status() {
    status_msg="$1"
    if command -v ksud >/dev/null 2>&1; then
        ksud module config set override.description "$status_msg" 2>/dev/null
    fi
}

log() {
    echo "[*] $(date '+%Y-%m-%d %H:%M:%S'): [CLI] $1" >> "$LOG_FILE"
    rotate_log
}

rotate_log() {
    line_count=$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    if [ "$line_count" -gt "$LOG_MAX_LINES" ]; then
        tmp="${LOG_FILE}.tmp"
        tail -n "$LOG_MAX_LINES" "$LOG_FILE" > "$tmp" && mv "$tmp" "$LOG_FILE"
    fi
}

# -------------------------------------------------------------------
# Config helpers
# -------------------------------------------------------------------
get_current_val() {
    local key="$1"
    local default="$2"

    if [ -f "$CONFIG_FILE" ]; then
        local val
        val=$(grep "\"$key\"" "$CONFIG_FILE" 2>/dev/null | \
              sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p" | \
              head -n 1)
        if [ -n "$val" ] && [ "$val" -ge 0 ] 2>/dev/null; then
            echo "$val"
        else
            echo "$default"
        fi
    else
        echo "$default"
    fi
}

update_config() {
    local key="$1"
    local value="$2"

    if [ ! -f "$CONFIG_FILE" ]; then
        echo "⚠ Config file not found!"
        return 1
    fi

    if ! echo "$value" | grep -qE '^[0-9]+$'; then
        echo "✗ Invalid value: $value (must be a number)"
        return 1
    fi

    cp "$CONFIG_FILE" "${CONFIG_FILE}.bak" 2>/dev/null

    if sed -E "s/(\"$key\"[[:space:]]*:[[:space:]]*)[0-9]+/\1${value}/" \
           "$CONFIG_FILE" > "${CONFIG_FILE}.tmp" 2>/dev/null; then
        mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
        echo "✓ Updated $key to $value seconds."
        log "Config updated: $key = $value"
        touch "$CONFIG_DIR/reload.flag" 2>/dev/null
        log "🔄 Reload flag set — service will apply changes within ~10s"
        return 0
    else
        [ -f "${CONFIG_FILE}.bak" ] && mv "${CONFIG_FILE}.bak" "$CONFIG_FILE"
        rm -f "${CONFIG_FILE}.tmp" 2>/dev/null
        echo "✗ Failed to update config!"
        log "Config update failed for $key"
        return 1
    fi
}

# -------------------------------------------------------------------
# find_lib: cached libshizuku.so lookup (fast path = cache hit)
# -------------------------------------------------------------------
find_lib() {
    if [ -f "$LIB_CACHE" ]; then
        cached=$(cat "$LIB_CACHE")
        if [ -n "$cached" ] && [ -f "$cached" ]; then
            echo "$cached"
            return 0
        else
            rm -f "$LIB_CACHE"
        fi
    fi

    result=$(timeout 5 find /data/app/ -type f -name "libshizuku.so" 2>/dev/null | head -n 1)
    if [ -n "$result" ]; then
        echo "$result" > "$LIB_CACHE"
        echo "$result"
        return 0
    fi

    return 1
}

# -------------------------------------------------------------------
# Shizuku start / stop
# -------------------------------------------------------------------
start_shizuku() {
    if pidof shizuku_server >/dev/null 2>&1; then
        echo "💓 Shizuku is already running."
        update_ksu_status "💓 Shizuku Running | Watchdog Active ✅"
        return 0
    fi

    echo "🚀 Starting Shizuku..."
    update_ksu_status "🔄 Ashizw: Starting Shizuku..."

    LIB_PATH=$(find_lib)

    if [ -z "$LIB_PATH" ]; then
        echo "❌ ERROR: libshizuku.so not found! (Shizuku installed?)"
        log "Binary not found"
        update_ksu_status "❌ Ashizw: libshizuku.so Not Found"
        return 1
    fi

    echo "📍 Located: $LIB_PATH"
    chmod 755 "$LIB_PATH" 2>/dev/null
    "$LIB_PATH"
    RET=$?

    if [ "$RET" -eq 0 ]; then
        echo "💓 SUCCESS: Shizuku started."
        log "Started via CLI"
        update_ksu_status "✅ Ashizw: Shizuku Restored Successfully"
        sleep 3
        update_ksu_status "💓 Shizuku Running | Watchdog Active ✅"
    else
        echo "❌ FAILED: Exit code $RET"
        log "Failed to start via CLI"
        update_ksu_status "⚠️ Ashizw: Start Failed (Code: $RET)"
    fi
}

stop_shizuku() {
    if ! pidof shizuku_server >/dev/null 2>&1; then
        echo "⚠️  Shizuku is already stopped."
        update_ksu_status "⚠️ Shizuku Stopped | Tap Action to Start"
        return 0
    fi

    echo "🛑 Stopping Shizuku..."
    update_ksu_status "🛑 Ashizw: Stopping Shizuku..."

    # BUG FIX: these were on one line before — now correctly separated
    pkill -f shizuku_server 2>/dev/null
    pkill -f shizuku 2>/dev/null
    sleep 2

    if ! pidof shizuku_server >/dev/null 2>&1; then
        echo "✅ Shizuku stopped successfully."
        log "Stopped via CLI"
        update_ksu_status "⚠️ Shizuku Stopped | Tap Action to Start"
        return 0
    else
        echo "❌ Failed to stop Shizuku."
        log "Failed to stop via CLI"
        update_ksu_status "⚠️ Ashizw: Stop Failed"
        return 1
    fi
}

print_status() {
    if pidof shizuku_server >/dev/null 2>&1; then
        echo "💓 Status: Shizuku is RUNNING"
    else
        echo "⚠️  Status: Shizuku is STOPPED"
    fi
}

show_help_text() {
    cat << 'EOF'
==================================
   ✦ Ashizw Commands ✦
==================================
ashizw start            : Start Shizuku
ashizw stop             : Stop Shizuku
ashizw status           : Check Status
ashizw set_delay <s>    : Set Boot Delay (seconds)
ashizw set_interval <s> : Set Check Interval (seconds)
ashizw menu             : Open Interactive Menu
ashizw help             : Show this help
==================================
EOF
}

show_menu() {
    while true; do
        clear
        echo "=================================="
        echo "   ✦ Ashizw Manager ✦"
        echo "=================================="
        print_status
        echo "=================================="
        echo "1. Start Shizuku"
        echo "2. Stop Shizuku"
        echo "3. Settings (Delay/Interval)"
        echo "4. Help/Commands"
        echo "5. Exit"
        echo "=================================="
        echo -n "Select an option [1-5]: "
        read CHOICE

        case $CHOICE in
            1) start_shizuku ;;
            2) stop_shizuku ;;
            3)
                echo ""
                echo "1. Set Boot Delay"
                echo "2. Set Check Interval"
                echo -n "Select setting [1-2]: "
                read SUB
                echo ""
                if [ "$SUB" = "1" ]; then
                    CURR=$(get_current_val "boot_delay" "45")
                    echo -n "Enter Boot Delay (Current: ${CURR}s, Default: 45s): "
                    read VAL
                    [ -n "$VAL" ] && update_config "boot_delay" "$VAL"
                elif [ "$SUB" = "2" ]; then
                    CURR=$(get_current_val "check_interval" "1800")
                    echo -n "Enter Check Interval (Current: ${CURR}s, Default: 1800s): "
                    read VAL
                    [ -n "$VAL" ] && update_config "check_interval" "$VAL"
                else
                    echo "Invalid selection"
                fi
                ;;
            4) show_help_text ;;
            5) echo "✦ Goodbye!"; exit 0 ;;
            *) echo "Invalid option" ;;
        esac

        echo ""
        echo "Press Enter to continue..."
        read -r
    done
}

# ============================================================
# MAIN LOGIC
# ============================================================
if [ -z "$1" ]; then
    show_menu
    exit 0
fi

case "$1" in
    s|status)
        print_status
        ;;
    r|start|run)
        start_shizuku
        ;;
    k|stop|kill)
        stop_shizuku
        ;;
    m|menu)
        show_menu
        ;;
    c|config)
        echo "✦ Config Path: $CONFIG_FILE"
        [ -f "$CONFIG_FILE" ] && cat "$CONFIG_FILE"
        ;;
    set_delay)
        if [ -n "$2" ] && echo "$2" | grep -qE '^[0-9]+$'; then
            update_config "boot_delay" "$2"
        else
            echo "✗ Usage: ashizw set_delay <seconds>"
        fi
        ;;
    set_interval)
        if [ -n "$2" ] && echo "$2" | grep -qE '^[0-9]+$'; then
            update_config "check_interval" "$2"
        else
            echo "✗ Usage: ashizw set_interval <seconds>"
        fi
        ;;
    h|help|--help)
        show_help_text
        ;;
    *)
        echo "✗ Unknown command: $1"
        show_help_text
        exit 1
        ;;
esac
